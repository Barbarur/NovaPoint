<UserControl x:Class="NovaPointWPF.UserControls.AdminForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NovaPointWPF.UserControls"
             xmlns:npusercontrols="clr-namespace:NovaPointWPF.Controls.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="root">
    
    <Grid
        Background="Transparent">

        <StackPanel>

            <npusercontrols:FilterTitle
                x:Name="FilterTitleLabel"
                Title="Site Collection Administrator is required to run the Solution"
                LearnMoreLink="https://github.com/Barbarur/NovaPoint/wiki/Parameters-SPOAdminAccessParameters"/>


            <Grid Style="{DynamicResource SolutionMenuGrid}">

                <Border Style="{DynamicResource BorderPrimaryBackgroud}">

                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.45*"/>
                                <ColumnDefinition Width="0.55*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock
                                    Style="{DynamicResource TextBlockBody}"
                                    HorizontalAlignment="Center">
                                    <TextBlock.Inlines>
                                        <Run FontWeight="Bold" TextDecorations="Underline" Text="Add"/>
                                        <Run Text="my account as Site Collection Admin."/>
                                    </TextBlock.Inlines>
                                </TextBlock>

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0">

                                    <RadioButton
                                        Style="{DynamicResource ToggleButtonSolutionForm}"
                                        Content="Yes"
                                        Width="120"
                                        IsChecked="{Binding AddAdmin, Mode=TwoWay, ElementName=root}"
                                        Margin="0,0,8,0"/>

                                    <RadioButton
                                        Style="{DynamicResource ToggleButtonSolutionForm}"
                                        Width="120"
                                        Content="No"
                                        IsChecked="True"/>

                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1">

                                <TextBlock
                                    Style="{DynamicResource TextBlockBody}"
                                    HorizontalAlignment="Center">
                                    <TextBlock.Inlines>
                                        <Run FontWeight="Bold" TextDecorations="Underline" Text="Remove"/>
                                        <Run Text="my account as Site Collection Admin at the end."/>
                                    </TextBlock.Inlines>

                                </TextBlock>

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0">

                                    <RadioButton
                                        Style="{DynamicResource ToggleButtonSolutionForm}"
                                        Content="Yes"
                                        Width="120"
                                        IsChecked="{Binding RemoveAdmin, Mode=TwoWay, ElementName=root}"
                                        Margin="0,0,8,0"/>

                                    <RadioButton
                                        Style="{DynamicResource ToggleButtonSolutionForm}"
                                        Width="120"
                                        Content="No"
                                        IsChecked="True"/>

                                </StackPanel>

                            </StackPanel>


                        </Grid>

                        <TextBlock
                            Style="{DynamicResource TextBlockBody}"
                            Margin="0, 12, 0, 0">
                            <TextBlock.Inlines>
                                <Run FontWeight="Bold" Text="Important:"/>
                                <Run Text="These parameters will only apply when using a"/>
                                <Run TextDecorations="Underline" Text="delegated app."/>
                            </TextBlock.Inlines>
                        </TextBlock>

                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
